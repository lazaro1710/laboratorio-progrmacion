int opcion = 0;
string nombre = "";

while (opcion != 4)
{
    Console.WriteLine("\n--- MENU ---");
    Console.WriteLine("1. Cargar nombre de alumno");
    Console.WriteLine("2. Mostrar edad");
    Console.WriteLine("3. Mostrar promedio de notas");
    Console.WriteLine("4. SALIR");
    Console.Write("Seleccione una opcion: ");

    string? input = Console.ReadLine(); 

    if (int.TryParse(input, out opcion))
    {
        if (opcion == 1)
        {
            Console.Write("Ingrese el nombre: ");
            
            nombre = Console.ReadLine() ?? ""; 
            Console.WriteLine("Alumno guardado.");
        }
        else if (opcion == 2)
        {
            Console.Write("Ingrese la edad: ");
            
            string? edad = Console.ReadLine(); 
            Console.WriteLine("Edad registrada.");
        }
        else if (opcion == 3)
        {
            Console.Write("Ingrese el promedio: ");
            
            string? promedio = Console.ReadLine(); 
            Console.WriteLine("Promedio registrado.");
        }
        else if (opcion == 4)
        {
            Console.WriteLine("Fin del programa.");
        }
        else
        {
            Console.WriteLine("Esa opción no existe.");
        }
    }
    else
    {
        Console.WriteLine("Por favor, escribe un número.");
    }
}




